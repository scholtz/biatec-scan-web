{
  "name": "vite-vue-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "generate:api": "orval --config orval.config.ts",
    "check-localization-files": "tsx scripts/check-localization.ts",
    "check-phrases": "tsx scripts/translate-untranslated.ts",
    "check-typescript-errors-tsc": "tsc --noEmit",
    "check-typescript-errors-vue": "vue-tsc --noEmit",
    "lint": "eslint src/**/*.{ts,vue} --ext .ts,.vue",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@microsoft/signalr": "^9.0.6",
    "algosdk": "^3.6.0",
    "arc14": "^1.0.4",
    "arc76": "^1.0.2",
    "axios": "^1.18.0",
    "buffer": "^6.0.3",
    "uuidv7": "^1.2.1",
    "vue": "^3.4.38",
    "vue-i18n": "^11.4.7",
    "vue-router": "^4.6.4",
    "whatamesh": "^0.2.0"
  },
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "@eslint/js": "^9.32.0",
    "@intlify/unplugin-vue-i18n": "^11.2.4",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.13.2",
    "@types/vue-i18n": "^7.0.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.8.0",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^16.5.0",
    "jiti": "^2.7.0",
    "orval": "^8.17.0",
    "prettier": "^3.8.4",
    "prettier-eslint": "^17.0.1",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^2.2.12"
  }
}
