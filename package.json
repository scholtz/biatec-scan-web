{
  "name": "vite-vue-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "generate:api": "orval --config orval.config.ts",
    "check-localization-files": "npx tsx scripts/check-localization.ts",
    "check-phrases": "npx tsx scripts/translate-untranslated.ts",
    "check-typescript-errors-tsc": "npx tsc --noEmit",
    "check-typescript-errors-vue": "npx vue-tsc --noEmit",
    "lint": "eslint src/**/*.{ts,vue} --ext .ts,.vue"
  },
  "dependencies": {
    "@microsoft/signalr": "^9.0.6",
    "algosdk": "^3.5.2",
    "arc14": "^1.0.4",
    "arc76": "^1.0.2",
    "axios": "^1.15.0",
    "uuidv7": "^1.2.1",
    "vue": "^3.4.38",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.6.4",
    "whatamesh": "^0.2.0"
  },
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "@eslint/js": "^9.32.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/vue-i18n": "^6.1.3",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "orval": "^7.21.0",
    "prettier": "^3.8.2",
    "prettier-eslint": "^16.4.2",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^5.4.21",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.2.12"
  }
}
